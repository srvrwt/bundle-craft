<div class="bundle-builder-container">
  <h2>{{ section.settings.heading }}</h2>

  <div id="bundle-products"></div>

  <div class="bundle-summary">
    <p>Total Price: <span id="bundle-total">0</span></p>
    <button id="add-bundle" class="bundle-btn">Add Bundle to Cart</button>
  </div>
</div>

{% schema %}
{
  "name": "Bundle Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create Your Bundle"
    }
  ],
  "javascript": "bundle-builder.js",
  "stylesheet": "bundle-builder.css"
}
{% endschema %}
